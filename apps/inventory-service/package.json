{
  "name": "@foodiego/inventory-service",
  "version": "1.0.0",
  "description": "Inventory management and reservation service",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "seed:inventory": "node scripts/seed.js",
    "reset:inventory": "node scripts/reset.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "dependencies": {
    "@foodiego/core": "workspace:*",
    "@foodiego/logging": "workspace:*",
    "@foodiego/metrics": "workspace:*",
    "@foodiego/platform-sdk": "workspace:*",
    "@foodiego/rabbit": "workspace:*",
    "@foodiego/tracing": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "helmet": "^7.2.0",
    "morgan": "^1.11.0",
    "pg": "^8.11.5",
    "@opentelemetry/api": "^1.9.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  }
}