{
  "name": "order-service",
  "version": "1.0.0",
  "description": "FoodieGo Order, Cart & Delivery Service",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --testPathPattern=\"(auth.middleware|delivery.model|order.routes)\"",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --testPathPattern=\"routes\"",
    "order:update-status": "node scripts/update-order-status.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "dependencies": {
    "@foodiego/contracts": "workspace:*",
    "@foodiego/core": "workspace:*",
    "@foodiego/logging": "workspace:*",
    "@foodiego/metrics": "workspace:*",
    "@foodiego/platform-sdk": "workspace:*",
    "@foodiego/rabbit": "workspace:*",
    "@foodiego/shared-auth": "workspace:*",
    "@foodiego/tracing": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 0,
        "functions": 0,
        "branches": 0,
        "statements": 0
      }
    }
  }
}