{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Dispatch Cycle Duration (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(dispatcher_batch_duration_ms_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.50, sum(rate(dispatcher_batch_duration_ms_bucket[5m])) by (le))", "legendFormat": "P50" }
      ]
    },
    {
      "title": "Dispatcher Batch Size",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(dispatcher_batch_size_bucket[5m])) by (le))", "legendFormat": "P95 Batch" }
      ]
    },
    {
      "title": "Outbox Backlog (Pending Events)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "dispatcher_backlog", "legendFormat": "Backlog" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}] } } }
    },
    {
      "title": "Event Publish Duration P95 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(event_publish_duration_ms_bucket[5m])) by (le, event_type))", "legendFormat": "{{event_type}}" }
      ]
    },
    {
      "title": "Consumer Processing P95 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(event_consume_duration_ms_bucket[5m])) by (le, consumer))", "legendFormat": "{{consumer}}" }
      ]
    },
    {
      "title": "Retry Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(rate(event_retry_total[5m])) by (event_type)", "legendFormat": "{{event_type}}" }
      ]
    },
    {
      "title": "DLQ Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum(rate(event_dlq_total[5m]))", "legendFormat": "DLQ/sec" }
      ]
    },
    {
      "title": "Inbox Duplicates Dropped",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        { "expr": "sum(rate(inbox_duplicate_total[5m]))", "legendFormat": "Dupes/sec" }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["foodiego", "messaging"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "FoodieGo Messaging Runtime",
  "uid": "foodiego-messaging"
}
