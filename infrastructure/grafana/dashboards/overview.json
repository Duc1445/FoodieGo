  "liveNow": false,
  "panels": [
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_total[5m])) by (service)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "title": "HTTP P95 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "title": "HTTP Error Rate (5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_total{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_total[5m])) * 100", "legendFormat": "Error %" }
      ]
    },
    {
      "title": "Dispatcher Backlog",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "dispatcher_backlog", "legendFormat": "Pending Events" }
      ]
    },
    {
      "title": "Event Consumer P95 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(event_consume_duration_ms_bucket[5m])) by (le, consumer))", "legendFormat": "{{consumer}}" }
      ]
    },
    {
      "title": "DLQ Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(event_dlq_total)", "legendFormat": "DLQ Events" }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "expr": "sum(rate(cache_hit_total[5m])) / (sum(rate(cache_hit_total[5m])) + sum(rate(cache_miss_total[5m]))) * 100", "legendFormat": "Hit %" }
      ]
    },
    {
      "title": "DB Query P95 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "{{service}}" }
      ]
    }
  ],
