{
  "name": "foodiego",
  "version": "1.0.0",
  "description": "FoodieGo is a modern, microservices-based application built with Node.js, Express, PostgreSQL, and Redis, designed using a Layered Domain-Driven Design (DDD) architecture.",
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test",
    "test:integration": "pnpm -r run --if-present test:integration",
    "test:contracts": "node scripts/test-contracts.js",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r exec tsc -b",
    "dev": "pnpm -r run dev",
    "seed": "node scripts/seed.js",
    "seed:users": "node scripts/seed/users.js",
    "seed:restaurant": "node scripts/seed/restaurant.js",
    "seed:inventory": "node scripts/seed/inventory.js",
    "seed:all": "pnpm run seed:users && pnpm run seed:restaurant && pnpm run seed:inventory",
    "prepare": "husky",
    "demo:seed": "node scripts/demo/generate-realistic-data.js && node scripts/demo/demo-seed.js",
    "demo:reset": "node scripts/demo/demo-reset.js && pnpm demo:seed",
    "demo:verify": "node scripts/demo/demo-verify.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}