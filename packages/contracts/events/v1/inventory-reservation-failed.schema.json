{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://foodiego.com/schemas/v1/inventory-reservation-failed.schema.json",
  "title": "InventoryReservationFailed",
  "type": "object",
  "allOf": [
    { "$ref": "../common/event-metadata.schema.json" }
  ],
  "properties": {
    "schemaVersion": { "const": "v1" },
    "eventType": { "const": "InventoryReservationFailed" },
    "aggregateType": { "const": "Inventory" },
    "aggregateId": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "reason": { "type": "string" },
        "failedItems": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["restaurantId", "reason"],
      "additionalProperties": false
    }
  },
  "required": ["eventType", "aggregateType", "aggregateId", "payload"]
}
