{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://foodiego.com/schemas/v1/inventory-reserved.schema.json",
  "title": "InventoryReserved",
  "type": "object",
  "allOf": [
    { "$ref": "../common/event-metadata.schema.json" }
  ],
  "properties": {
    "schemaVersion": { "const": "v1" },
    "eventType": { "const": "InventoryReserved" },
    "aggregateType": { "const": "Inventory" },
    "aggregateId": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "reservationId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "expiresAt": { "$ref": "../common/timestamp.schema.json" }
      },
      "required": ["reservationId", "restaurantId", "expiresAt"],
      "additionalProperties": false
    }
  },
  "required": ["eventType", "aggregateType", "aggregateId", "payload"]
}
