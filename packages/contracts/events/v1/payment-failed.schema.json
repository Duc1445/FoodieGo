{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://foodiego.com/schemas/v1/payment-failed.schema.json",
  "title": "PaymentFailed",
  "type": "object",
  "allOf": [
    { "$ref": "../common/event-metadata.schema.json" }
  ],
  "properties": {
    "schemaVersion": { "const": "v1" },
    "eventType": { "const": "PaymentFailed" },
    "aggregateType": { "const": "Payment" },
    "aggregateId": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "provider": {
          "type": "string",
          "enum": ["STRIPE", "VNPAY"]
        },
        "reason": { "type": "string" },
        "errorCode": { "type": "string" }
      },
      "required": ["provider", "reason"],
      "additionalProperties": false
    }
  },
  "required": ["eventType", "aggregateType", "aggregateId", "payload"]
}
