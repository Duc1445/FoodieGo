{
  "$id": "https://foodiego.com/schemas/events/food/FoodPublishedV1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FoodPublishedV1",
  "type": "object",
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "FoodPublishedV1" },
    "eventVersion": { "const": 1 },
