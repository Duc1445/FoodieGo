{
  "$id": "https://foodiego.com/schemas/events/inventory/InventoryReservedV1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InventoryReservedV1",
  "type": "object",
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "InventoryReservedV1" },
    "eventVersion": { "const": 1 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "aggregateId": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "reservationId": { "type": "string", "format": "uuid" },
        "orderId": { "type": "string", "format": "uuid" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "foodId": { "type": "string", "format": "uuid" },
              "variantId": { "type": "string", "format": "uuid" },
              "quantity": { "type": "integer" }
            },
            "required": ["foodId", "variantId", "quantity"]
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["reservationId", "orderId", "items", "timestamp"],
      "additionalProperties": false
    }
  },
  "required": [
    "eventId", "eventType", "eventVersion", "occurredAt", "correlationId", "causationId", "aggregateId", "payload"
  ],
  "additionalProperties": false
}
