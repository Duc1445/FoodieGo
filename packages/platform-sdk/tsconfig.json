{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": false,
    "declaration": true,
    "outDir": "./dist",
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["index.js", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
