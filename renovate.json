{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":preserveSemverRanges",
    ":dependencyDashboard",
    "group:allNonMajor"
  ],
  "automerge": false,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["@types/**"],
      "automerge": false
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "legacy/**"
  ]
}
